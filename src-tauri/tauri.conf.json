{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MxSend",
  "version": "0.1.7",
  "identifier": "com.max-essien.MxSend",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MxSend",
        "width": 1024,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*.[pP][nN][gG]",
          "**/*.[jJ][pP][gG]",
          "**/*.[jJ][pP][eE][gG]",
          "**/*.[wW][eE][bB][pP]",
          "**/*.[gG][iI][fF]"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
